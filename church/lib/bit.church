(#import bi: {church/built_in})
(#enum 'b8 bi:'b8 [
	_0 {0000_0001}
	_1 {0000_0010}
	_2 {0000_0100}
	_3 {0000_1000}
	_4 {0001_0000}
	_5 {0010_0000}
	_6 {0100_0000}
	_7 {1000_0000}
])
(#proc ~u8__is_on [value bi:'u8 bit 'b8] [is_on 'bool] [
	(#set is_on (#has_matching_bits (#bitwise_and (#get_backing_type bit) value) value))
])
(#proc_group ~is_on [
	~u8__is_on
])
